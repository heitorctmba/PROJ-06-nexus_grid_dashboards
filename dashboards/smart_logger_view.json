        "afterRender": "",
        "content": "<style>\n/* ===========================================\n   LOGGER TABLE - BEM CSS\n   =========================================== */\n\n.logger-table {\n  font-family: Inter, system-ui, sans-serif;\n  width: 100%;\n  border-collapse: separate;\n  border-spacing: 0;\n  border-radius: 10px;\n  overflow: hidden;\n  font-size: 12px;\n}\n\n.logger-table__thead {\n  background: linear-gradient(135deg, rgba(33,38,45,1), rgba(28,33,40,1));\n}\n\n.logger-table__thead th {\n  padding: 12px 10px;\n  text-align: left;\n  font-weight: 600;\n  font-size: 10px;\n  letter-spacing: 0.5px;\n  text-transform: uppercase;\n  color: #8b949e;\n  border-bottom: 1px solid #30363d;\n}\n\n.logger-table__row {\n  transition: all 0.15s ease;\n  cursor: pointer;\n}\n\n.logger-table__row:nth-child(odd) { background: rgba(22,27,34,0.8); }\n.logger-table__row:nth-child(even) { background: rgba(28,33,40,0.8); }\n.logger-table__row:hover { background: rgba(48,54,61,0.9) !important; }\n\n.logger-table__row td {\n  padding: 10px;\n  border-bottom: 1px solid rgba(48,54,61,0.5);\n  vertical-align: middle;\n  color: #e6edf3;\n}\n\n/* Status badge */\n.logger-table__status {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  padding: 4px 10px;\n  border-radius: 6px;\n  font-size: 10px;\n  font-weight: 600;\n  text-transform: uppercase;\n}\n\n.logger-table__status--online {\n  background: rgba(34,197,94,0.15);\n  color: #4ade80;\n  border: 1px solid rgba(34,197,94,0.3);\n}\n\n.logger-table__status--offline {\n  background: rgba(107,114,128,0.15);\n  color: #9ca3af;\n  border: 1px solid rgba(107,114,128,0.3);\n}\n\n.logger-table__dot {\n  width: 6px;\n  height: 6px;\n  border-radius: 50%;\n  background: currentColor;\n}\n\n/* Device name link */\n.logger-table__name {\n  font-weight: 500;\n  color: #58a6ff;\n  text-decoration: none;\n  transition: color 0.15s ease;\n}\n\n.logger-table__name:hover {\n  color: #79b8ff;\n  text-decoration: underline;\n}\n\n/* Values */\n.logger-table__value {\n  font-variant-numeric: tabular-nums;\n}\n\n.logger-table__value--power {\n  color: #58a6ff;\n  font-weight: 500;\n}\n\n.logger-table__value--energy {\n  color: #a371f7;\n}\n\n.logger-table__value--efficiency {\n  font-weight: 500;\n}\n\n.logger-table__value--good { color: #4ade80; }\n.logger-table__value--warning { color: #fbbf24; }\n.logger-table__value--bad { color: #f87171; }\n\n.logger-table__unit {\n  font-size: 9px;\n  color: #6b7280;\n  margin-left: 2px;\n}\n\n/* Timestamp */\n.logger-table__time {\n  font-size: 11px;\n  color: #8b949e;\n  font-variant-numeric: tabular-nums;\n}\n\n.logger-table__na {\n  color: #6b7280;\n  font-style: italic;\n}\n</style>\n\n<table class=\"logger-table\">\n  <thead class=\"logger-table__thead\">\n    <tr>\n      <th style=\"width: 80px;\">Status</th>\n      <th style=\"width: 140px;\">Logger</th>\n      <th style=\"width: 60px;\">Cabin</th>\n      <th>Active Power</th>\n      <th>Daily Energy</th>\n      <th>Cumulative Energy</th>\n      <th>Efficiency</th>\n      <th>Inverters</th>\n      <th style=\"width: 130px;\">Last Reading</th>\n    </tr>\n  </thead>\n  <tbody>\n    {{#each data}}\n    <tr class=\"logger-table__row\" onclick=\"window.location.href='/d/adsn27w/device-view?var-device_id={{this.device_id}}&var-power_plant_id={{this.power_plant_id}}'\">\n      <td>\n        <span class=\"logger-table__status {{statusClass this.timestamp}}\">\n          <span class=\"logger-table__dot\"></span>\n          {{statusLabel this.timestamp}}\n        </span>\n      </td>\n      <td>\n        <a href=\"/d/adsn27w/device-view?var-device_id={{this.device_id}}&var-power_plant_id={{this.power_plant_id}}\" class=\"logger-table__name\" onclick=\"event.stopPropagation()\">\n          {{this.logger_name}}\n        </a>\n      </td>\n      <td>{{this.cabin}}</td>\n      <td>{{#if this.timestamp}}<span class=\"logger-table__value logger-table__value--power\">{{this.active_power_kw}}<span class=\"logger-table__unit\">kW</span></span>{{else}}<span class=\"logger-table__na\">—</span>{{/if}}</td>\n      <td>{{#if this.timestamp}}<span class=\"logger-table__value logger-table__value--energy\">{{this.daily_energy_kwh}}<span class=\"logger-table__unit\">kWh</span></span>{{else}}<span class=\"logger-table__na\">—</span>{{/if}}</td>\n      <td>{{#if this.timestamp}}<span class=\"logger-table__value\">{{this.cumulative_energy_mwh}}<span class=\"logger-table__unit\">MWh</span></span>{{else}}<span class=\"logger-table__na\">—</span>{{/if}}</td>\n      <td>{{#if this.timestamp}}<span class=\"logger-table__value logger-table__value--efficiency {{efficiencyColor this.efficiency_pct}}\">{{this.efficiency_pct}}<span class=\"logger-table__unit\">%</span></span>{{else}}<span class=\"logger-table__na\">—</span>{{/if}}</td>\n      <td>{{#if this.timestamp}}<span class=\"logger-table__value\">{{this.inverters_producing}}</span>{{else}}<span class=\"logger-table__na\">—</span>{{/if}}</td>\n      <td>{{#if this.timestamp}}<span class=\"logger-table__time\">{{this.last_reading}}</span>{{else}}<span class=\"logger-table__na\">No data</span>{{/if}}</td>\n    </tr>\n    {{/each}}\n  </tbody>\n</table>",
        "contentPartials": [],
        "defaultContent": "No smart loggers found for this power plant.",
        "editor": {
          "format": "auto",
          "language": "html"
        },
        "editors": [
          "helpers"
        ],
        "externalStyles": [],
        "helpers": "// Status class based on timestamp presence\ncontext.handlebars.registerHelper('statusClass', function(timestamp) {\n  return timestamp ? 'logger-table__status--online' : 'logger-table__status--offline';\n});\n\n// Status label\ncontext.handlebars.registerHelper('statusLabel', function(timestamp) {\n  return timestamp ? 'Online' : 'Offline';\n});\n\n// Efficiency color\ncontext.handlebars.registerHelper('efficiencyColor', function(value) {\n  if (value >= 95) return 'logger-table__value--good';\n  if (value >= 80) return 'logger-table__value--warning';\n  return 'logger-table__value--bad';\n});",
        "renderMode": "allRows",
        "styles": "",
        "wrap": true
      },
      "pluginVersion": "6.2.0",
      "targets": [
        {
          "dataset": "powerplants",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n    d.id as device_id,\n    pp.id as power_plant_id,\n    d.device_name as logger_name,\n    COALESCE(d.cabin, 0) as cabin,\n    ROUND(COALESCE(lr.active_power, 0)::numeric, 2) as active_power_kw,\n    ROUND(COALESCE(lr.daily_active_energy, 0)::numeric, 2) as daily_energy_kwh,\n    ROUND(COALESCE(lr.cumulative_active_energy, 0)::numeric / 1000, 2) as cumulative_energy_mwh,\n    ROUND(COALESCE(lr.efficiency, 0)::numeric, 1) as efficiency_pct,\n    COALESCE(lr.inverters_producing_count, 0) as inverters_producing,\n    lr.timestamp,\n    TO_CHAR(lr.timestamp, 'DD/MM/YY HH24:MI') as last_reading\nFROM public.tb_devices d\nJOIN public.tb_power_plants pp ON pp.id = d.power_plant_id\nLEFT JOIN dbt.int_logger_latest_readings lr ON lr.device_id = d.id\nWHERE d.device_type_id = 3\n  AND d.is_active = true\n  AND d.power_plant_id = $power_plant_id\nORDER BY \n  CASE WHEN lr.timestamp IS NULL THEN 1 ELSE 0 END,\n  d.device_name",
          "refId": "A",
