        "afterRender": "",
        "content": "<style>\n.logger-header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  padding: 12px 20px;\n  background: linear-gradient(135deg, rgba(45,45,50,0.95), rgba(35,35,40,0.95));\n  border-radius: 10px;\n  border: 1px solid rgba(255,255,255,0.08);\n  font-family: Inter, system-ui, sans-serif;\n}\n.logger-header__nav {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n}\n.logger-header__back {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  padding: 8px 16px;\n  background: rgba(99,102,241,0.1);\n  border: 1px solid rgba(99,102,241,0.25);\n  border-radius: 8px;\n  color: #818cf8;\n  text-decoration: none;\n  font-size: 13px;\n  font-weight: 500;\n  transition: all 0.2s ease;\n}\n.logger-header__back:hover {\n  background: rgba(99,102,241,0.2);\n  border-color: rgba(99,102,241,0.4);\n  transform: translateX(-2px);\n}\n.logger-header__title {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n.logger-header__name {\n  font-size: 16px;\n  font-weight: 600;\n  color: #e5e7eb;\n}\n.logger-header__subtitle {\n  font-size: 11px;\n  color: #6b7280;\n}\n.logger-header__stats {\n  display: flex;\n  gap: 20px;\n}\n.logger-header__stat {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  padding: 8px 16px;\n  background: rgba(30,30,35,0.6);\n  border-radius: 8px;\n  border: 1px solid rgba(255,255,255,0.05);\n}\n.logger-header__stat-value {\n  font-size: 18px;\n  font-weight: 600;\n}\n.logger-header__stat-value--green { color: #4ade80; }\n.logger-header__stat-value--yellow { color: #fbbf24; }\n.logger-header__stat-value--gray { color: #9ca3af; }\n.logger-header__stat-label {\n  font-size: 10px;\n  color: #6b7280;\n  text-transform: uppercase;\n}\n</style>\n\n<div class=\"logger-header\">\n  <div class=\"logger-header__nav\">\n    <a href=\"/d/ad4v9dd/powerplant-view?var-power_plant_id={{data.[0].power_plant_id}}\" class=\"logger-header__back\">\n      <span>←</span> Back\n    </a>\n    <div class=\"logger-header__title\">\n      <span class=\"logger-header__name\">{{data.[0].power_plant_name}}</span>\n      <span class=\"logger-header__subtitle\">Smart Loggers</span>\n    </div>\n  </div>\n  <div class=\"logger-header__stats\">\n    <div class=\"logger-header__stat\">\n      <span class=\"logger-header__stat-value logger-header__stat-value--green\">{{countOnline data}}</span>\n      <span class=\"logger-header__stat-label\">Online</span>\n    </div>\n    <div class=\"logger-header__stat\">\n      <span class=\"logger-header__stat-value logger-header__stat-value--gray\">{{countOffline data}}</span>\n      <span class=\"logger-header__stat-label\">Offline</span>\n    </div>\n  </div>\n</div>",
