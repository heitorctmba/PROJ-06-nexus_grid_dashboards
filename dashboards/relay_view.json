        "helpers": "context.handlebars.registerHelper('countNormal', function(data) {\n  return data.filter(d => !d.has_high_alarm).length;\n});\n\ncontext.handlebars.registerHelper('countAlarm', function(data) {\n  return data.filter(d => d.has_high_alarm).length;\n});",
