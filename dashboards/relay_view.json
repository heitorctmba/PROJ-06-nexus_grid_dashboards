        "afterRender": "",
        "content": "<style>\n/* ===========================================\n   RELAY TABLE - BEM CSS\n   =========================================== */\n\n.relay-table {\n  font-family: Inter, system-ui, sans-serif;\n  width: 100%;\n  border-collapse: separate;\n  border-spacing: 0;\n  border-radius: 10px;\n  overflow: hidden;\n  font-size: 12px;\n}\n\n.relay-table__thead {\n  background: linear-gradient(135deg, rgba(33,38,45,1), rgba(28,33,40,1));\n}\n\n.relay-table__thead th {\n  padding: 12px 10px;\n  text-align: left;\n  font-weight: 600;\n  font-size: 10px;\n  letter-spacing: 0.5px;\n  text-transform: uppercase;\n  color: #8b949e;\n  border-bottom: 1px solid #30363d;\n}\n\n.relay-table__row {\n  transition: all 0.15s ease;\n  cursor: pointer;\n}\n\n.relay-table__row:nth-child(odd) { background: rgba(22,27,34,0.8); }\n.relay-table__row:nth-child(even) { background: rgba(28,33,40,0.8); }\n.relay-table__row:hover { background: rgba(48,54,61,0.9) !important; }\n\n.relay-table__row td {\n  padding: 10px;\n  border-bottom: 1px solid rgba(48,54,61,0.5);\n  vertical-align: middle;\n  color: #e6edf3;\n}\n\n/* Status badge */\n.relay-table__status {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  padding: 4px 10px;\n  border-radius: 6px;\n  font-size: 10px;\n  font-weight: 600;\n  text-transform: uppercase;\n}\n\n.relay-table__status--normal {\n  background: rgba(34,197,94,0.15);\n  color: #4ade80;\n  border: 1px solid rgba(34,197,94,0.3);\n}\n\n.relay-table__status--alarm {\n  background: rgba(239,68,68,0.15);\n  color: #f87171;\n  border: 1px solid rgba(239,68,68,0.3);\n  animation: pulse-alarm 2s ease-in-out infinite;\n}\n\n@keyframes pulse-alarm {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.7; }\n}\n\n.relay-table__dot {\n  width: 6px;\n  height: 6px;\n  border-radius: 50%;\n  background: currentColor;\n}\n\n/* Device name link */\n.relay-table__name {\n  font-weight: 500;\n  color: #58a6ff;\n  text-decoration: none;\n  transition: color 0.15s ease;\n}\n\n.relay-table__name:hover {\n  color: #79b8ff;\n  text-decoration: underline;\n}\n\n/* Values */\n.relay-table__value {\n  font-variant-numeric: tabular-nums;\n}\n\n.relay-table__value--power {\n  color: #58a6ff;\n  font-weight: 500;\n}\n\n.relay-table__value--voltage {\n  color: #f0883e;\n}\n\n.relay-table__value--current {\n  color: #a371f7;\n}\n\n.relay-table__unit {\n  font-size: 9px;\n  color: #6b7280;\n  margin-left: 2px;\n}\n\n/* Timestamp */\n.relay-table__time {\n  font-size: 11px;\n  color: #8b949e;\n  font-variant-numeric: tabular-nums;\n}\n</style>\n\n<table class=\"relay-table\">\n  <thead class=\"relay-table__thead\">\n    <tr>\n      <th style=\"width: 80px;\">Status</th>\n      <th style=\"width: 140px;\">Relay</th>\n      <th style=\"width: 60px;\">Cabin</th>\n      <th>Active Power</th>\n      <th>Apparent Power</th>\n      <th>Voltage AB</th>\n      <th>Voltage BC</th>\n      <th>Voltage CA</th>\n      <th>Current A</th>\n      <th>Current B</th>\n      <th>Current C</th>\n      <th style=\"width: 130px;\">Last Reading</th>\n    </tr>\n  </thead>\n  <tbody>\n    {{#each data}}\n    <tr class=\"relay-table__row\" onclick=\"window.location.href='/d/adsn27w/device-view?var-device_id={{this.device_id}}&var-power_plant_id={{this.power_plant_id}}'\">\n      <td>\n        <span class=\"relay-table__status {{statusClass this.has_high_alarm}}\">\n          <span class=\"relay-table__dot\"></span>\n          {{statusLabel this.has_high_alarm}}\n        </span>\n      </td>\n      <td>\n        <a href=\"/d/adsn27w/device-view?var-device_id={{this.device_id}}&var-power_plant_id={{this.power_plant_id}}\" class=\"relay-table__name\" onclick=\"event.stopPropagation()\">\n          {{this.relay}}\n        </a>\n      </td>\n      <td>{{this.cabine}}</td>\n      <td><span class=\"relay-table__value relay-table__value--power\">{{this.potencia_ativa_kw}}<span class=\"relay-table__unit\">kW</span></span></td>\n      <td><span class=\"relay-table__value\">{{this.potencia_aparente_kva}}<span class=\"relay-table__unit\">kVA</span></span></td>\n      <td><span class=\"relay-table__value relay-table__value--voltage\">{{this.tensao_ab_v}}<span class=\"relay-table__unit\">V</span></span></td>\n      <td><span class=\"relay-table__value relay-table__value--voltage\">{{this.tensao_bc_v}}<span class=\"relay-table__unit\">V</span></span></td>\n      <td><span class=\"relay-table__value relay-table__value--voltage\">{{this.tensao_ca_v}}<span class=\"relay-table__unit\">V</span></span></td>\n      <td><span class=\"relay-table__value relay-table__value--current\">{{this.corrente_a_a}}<span class=\"relay-table__unit\">A</span></span></td>\n      <td><span class=\"relay-table__value relay-table__value--current\">{{this.corrente_b_a}}<span class=\"relay-table__unit\">A</span></span></td>\n      <td><span class=\"relay-table__value relay-table__value--current\">{{this.corrente_c_a}}<span class=\"relay-table__unit\">A</span></span></td>\n      <td><span class=\"relay-table__time\">{{this.ultima_leitura}}</span></td>\n    </tr>\n    {{/each}}\n  </tbody>\n</table>",
        "contentPartials": [],
        "defaultContent": "No relays found for this power plant.",
        "editor": {
          "format": "auto",
          "language": "html"
        },
        "editors": [
