      "targets": [
        {
          "dataset": "powerplants",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_alarm_state AS (\n    SELECT DISTINCT ON (device_id, code)\n        device_id,\n        code,\n        type,\n        severity\n    FROM dbt.int_events_alarms\n    WHERE device_type_id = 2\n      AND power_plant_id = $power_plant_id\n    ORDER BY device_id, code, timestamp DESC\n),\nactive_high_alarms AS (\n    SELECT DISTINCT device_id\n    FROM latest_alarm_state\n    WHERE severity = 'high'\n      AND type = 'alarm'\n)\nSELECT \n    d.id as device_id,\n    pp.id as power_plant_id,\n    pp.name as power_plant_name,\n    CASE WHEN aha.device_id IS NOT NULL THEN true ELSE false END as has_high_alarm\nFROM public.tb_devices d\nJOIN public.tb_power_plants pp ON pp.id = d.power_plant_id\nLEFT JOIN active_high_alarms aha ON aha.device_id = d.id\nWHERE d.device_type_id = 2\n  AND d.is_active = true\n  AND d.power_plant_id = $power_plant_id",
