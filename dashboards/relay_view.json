      "pluginVersion": "6.2.0",
      "targets": [
        {
          "dataset": "powerplants",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_alarm_state AS (\n    SELECT DISTINCT ON (device_id, code)\n        device_id,\n        code,\n        type,\n        severity\n    FROM dbt.int_events_alarms\n    WHERE device_type_id = 2\n      AND power_plant_id = $power_plant_id\n    ORDER BY device_id, code, timestamp DESC\n),\nactive_high_alarms AS (\n    SELECT DISTINCT device_id\n    FROM latest_alarm_state\n    WHERE severity = 'high'\n      AND type = 'alarm'\n)\nSELECT \n    d.id as device_id,\n    pp.id as power_plant_id,\n    d.device_name as relay,\n    COALESCE(d.cabin, 0) as cabine,\n    ROUND(COALESCE(rl.active_power, 0)::numeric, 2) as potencia_ativa_kw,\n    ROUND(COALESCE(rl.apparent_power, 0)::numeric, 2) as potencia_aparente_kva,\n    ROUND(COALESCE(rl.line_voltage_ab, 0)::numeric, 1) as tensao_ab_v,\n    ROUND(COALESCE(rl.line_voltage_bc, 0)::numeric, 1) as tensao_bc_v,\n    ROUND(COALESCE(rl.line_voltage_ca, 0)::numeric, 1) as tensao_ca_v,\n    ROUND(COALESCE(rl.current_phase_a, 0)::numeric, 1) as corrente_a_a,\n    ROUND(COALESCE(rl.current_phase_b, 0)::numeric, 1) as corrente_b_a,\n    ROUND(COALESCE(rl.current_phase_c, 0)::numeric, 1) as corrente_c_a,\n    TO_CHAR(rl.timestamp, 'DD/MM/YY HH24:MI') as ultima_leitura,\n    CASE WHEN aha.device_id IS NOT NULL THEN true ELSE false END as has_high_alarm\nFROM public.tb_devices d\nJOIN public.tb_power_plants pp ON pp.id = d.power_plant_id\nLEFT JOIN dbt.int_relay_latest_readings rl ON rl.device_id = d.id\nLEFT JOIN active_high_alarms aha ON aha.device_id = d.id\nWHERE d.device_type_id = 2\n  AND d.is_active = true\n  AND d.power_plant_id = $power_plant_id\nORDER BY \n  CASE WHEN aha.device_id IS NOT NULL THEN 0 ELSE 1 END,\n  d.device_name",
