        ],
        "externalStyles": [],
        "helpers": "// Status class\ncontext.handlebars.registerHelper('statusClass', function(hasAlarm) {\n  return hasAlarm ? 'relay-table__status--alarm' : 'relay-table__status--normal';\n});\n\n// Status label\ncontext.handlebars.registerHelper('statusLabel', function(hasAlarm) {\n  return hasAlarm ? 'Critical' : 'Normal';\n});",
        "renderMode": "allRows",
