      "pluginVersion": "6.2.0",
      "targets": [
        {
          "dataset": "powerplants",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH inverter_metrics AS (\n    SELECT \n        device_id,\n        MAX(CASE WHEN field_name = 'Active Power' THEN value_numeric END) as potencia_ativa_kw,\n        MAX(CASE WHEN field_name = 'Efficiency' THEN value_numeric END) as eficiencia_pct,\n        MAX(CASE WHEN field_name = 'Temperature: internal' THEN value_numeric END) as temperatura_c,\n        MAX(CASE WHEN field_name = 'Frequency' THEN value_numeric END) as frequencia_hz,\n        MAX(CASE WHEN field_name = 'Power Factor' THEN value_numeric END) as fator_potencia,\n        MAX(CASE WHEN field_name = 'State: Simplified' THEN value_numeric END) as state_simplified,\n        MAX(timestamp) as ultima_leitura\n    FROM dbt.int_inverter_latest_readings\n    WHERE power_plant_id = $power_plant_id\n    GROUP BY device_id\n)\nSELECT \n    d.id as device_id,\n    pp.id as power_plant_id,\n    d.device_name as inversor,\n    COALESCE(d.cabin, 0) as cabine,\n    ROUND(COALESCE(im.potencia_ativa_kw, 0)::numeric, 2) as potencia_kw,\n    ROUND(COALESCE(im.eficiencia_pct, 0)::numeric, 1) as eficiencia_pct,\n    ROUND(COALESCE(im.temperatura_c, 0)::numeric, 1) as temp_c,\n    ROUND(COALESCE(im.frequencia_hz, 0)::numeric, 2) as freq_hz,\n    ROUND(COALESCE(im.fator_potencia, 0)::numeric, 3) as fp,\n    COALESCE(im.state_simplified, 0)::integer as state_simplified,\n    TO_CHAR(im.ultima_leitura, 'DD/MM/YY HH24:MI') as ultima_leitura\nFROM public.tb_devices d\nJOIN public.tb_power_plants pp ON pp.id = d.power_plant_id\nLEFT JOIN inverter_metrics im ON im.device_id = d.id\nWHERE d.device_type_id = 1\n  AND d.is_active = true\n  AND d.power_plant_id = $power_plant_id\nORDER BY \n  CASE WHEN COALESCE(im.state_simplified, 0) != 2 THEN 0 ELSE 1 END,\n  device_id",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
