        "helpers": "context.handlebars.registerHelper(\"groupBy\", function (array, key) {\n  const grouped = {};\n  array.forEach(item => {\n    const groupKey = item[key];\n    if (!grouped[groupKey]) {\n      grouped[groupKey] = [];\n    }\n    grouped[groupKey].push(item);\n  });\n  return Object.entries(grouped).map(([k, v]) => ({ key: k, items: v }));\n});\n\ncontext.handlebars.registerHelper('cardStatusClass', function(state) {\n  return state === 2 ? 'strings-grid__status--ok' : 'strings-grid__status--critical';\n});\n\ncontext.handlebars.registerHelper('cardStatusLabel', function(state) {\n  return state === 2 ? 'OK' : 'CRITICAL';\n});\n\ncontext.handlebars.registerHelper('stringClass', function(current) {\n  return current >= 1 ? 'strings-grid__string--ok' : 'strings-grid__string--fault';\n});",
