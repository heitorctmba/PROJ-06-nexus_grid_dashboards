      "targets": [
        {
          "dataset": "powerplants",
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT DISTINCT ON (d.id)\n    d.id as device_id,\n    pp.id as power_plant_id,\n    pp.name as power_plant_name,\n    COALESCE(\n        (SELECT value_numeric::integer\n         FROM dbt.int_inverter_latest_readings r\n         WHERE r.device_id = d.id AND r.field_name = 'State: Simplified'\n         LIMIT 1),\n        0\n    ) AS state_simplified\nFROM public.tb_devices d\nJOIN public.tb_power_plants pp ON pp.id = d.power_plant_id\nWHERE d.device_type_id = 1\n  AND d.is_active = true\n  AND d.power_plant_id = $power_plant_id\n",
