      "options": {
        "afterRender": "",
        "content": "<style>\n/* ===========================================\n   INVERTER TABLE - BEM CSS\n   =========================================== */\n\n.inverter-table {\n  font-family: Inter, system-ui, sans-serif;\n  width: 100%;\n  border-collapse: separate;\n  border-spacing: 0;\n  border-radius: 10px;\n  overflow: hidden;\n  font-size: 11px;\n}\n\n.inverter-table__thead {\n  background: linear-gradient(135deg, rgba(33,38,45,1), rgba(28,33,40,1));\n}\n\n.inverter-table__thead th {\n  padding: 10px 8px;\n  text-align: left;\n  font-weight: 600;\n  font-size: 9px;\n  letter-spacing: 0.5px;\n  text-transform: uppercase;\n  color: #8b949e;\n  border-bottom: 1px solid #30363d;\n}\n\n.inverter-table__row {\n  transition: all 0.15s ease;\n  cursor: pointer;\n}\n\n.inverter-table__row:nth-child(odd) { background: rgba(22,27,34,0.8); }\n.inverter-table__row:nth-child(even) { background: rgba(28,33,40,0.8); }\n.inverter-table__row:hover { background: rgba(48,54,61,0.9) !important; }\n\n.inverter-table__row td {\n  padding: 8px;\n  border-bottom: 1px solid rgba(48,54,61,0.5);\n  vertical-align: middle;\n  color: #e6edf3;\n}\n\n/* Status badge */\n.inverter-table__status {\n  display: inline-flex;\n  align-items: center;\n  gap: 5px;\n  padding: 3px 8px;\n  border-radius: 5px;\n  font-size: 9px;\n  font-weight: 600;\n  text-transform: uppercase;\n}\n\n.inverter-table__status--generating {\n  background: rgba(34,197,94,0.15);\n  color: #4ade80;\n  border: 1px solid rgba(34,197,94,0.3);\n}\n\n.inverter-table__status--critical {\n  background: rgba(239,68,68,0.15);\n  color: #f87171;\n  border: 1px solid rgba(239,68,68,0.3);\n}\n\n.inverter-table__dot {\n  width: 5px;\n  height: 5px;\n  border-radius: 50%;\n  background: currentColor;\n}\n\n/* Device name link */\n.inverter-table__name {\n  font-weight: 500;\n  color: #58a6ff;\n  text-decoration: none;\n  transition: color 0.15s ease;\n}\n\n.inverter-table__name:hover {\n  color: #79b8ff;\n  text-decoration: underline;\n}\n\n/* Values */\n.inverter-table__value {\n  font-variant-numeric: tabular-nums;\n}\n\n.inverter-table__value--power {\n  color: #58a6ff;\n  font-weight: 600;\n}\n\n.inverter-table__value--efficiency {\n  font-weight: 500;\n}\n\n.inverter-table__value--good { color: #4ade80; }\n.inverter-table__value--warning { color: #fbbf24; }\n.inverter-table__value--bad { color: #f87171; }\n\n.inverter-table__unit {\n  font-size: 8px;\n  color: #6b7280;\n  margin-left: 1px;\n}\n\n/* Timestamp */\n.inverter-table__time {\n  font-size: 10px;\n  color: #8b949e;\n  font-variant-numeric: tabular-nums;\n}\n</style>\n\n<table class=\"inverter-table\">\n  <thead class=\"inverter-table__thead\">\n    <tr>\n      <th style=\"width: 70px;\">Status</th>\n      <th style=\"width: 110px;\">Inverter</th>\n      <th style=\"width: 50px;\">Cabin</th>\n      <th>Power</th>\n      <th>Efficiency</th>\n      <th>Temp</th>\n      <th>Freq</th>\n      <th>PF</th>\n      <th style=\"width: 100px;\">Last Reading</th>\n    </tr>\n  </thead>\n  <tbody>\n    {{#each data}}\n    <tr class=\"inverter-table__row\" onclick=\"window.location.href='/d/adsn27w/device-view?var-device_id={{this.device_id}}&var-power_plant_id={{this.power_plant_id}}'\">\n      <td>\n        <span class=\"inverter-table__status {{statusClass this.state_simplified}}\">\n          <span class=\"inverter-table__dot\"></span>\n          {{statusLabel this.state_simplified}}\n        </span>\n      </td>\n      <td>\n        <a href=\"/d/adsn27w/device-view?var-device_id={{this.device_id}}&var-power_plant_id={{this.power_plant_id}}\" class=\"inverter-table__name\" onclick=\"event.stopPropagation()\">\n          {{this.inversor}}\n        </a>\n      </td>\n      <td>{{this.cabine}}</td>\n      <td><span class=\"inverter-table__value inverter-table__value--power\">{{this.potencia_kw}}<span class=\"inverter-table__unit\">kW</span></span></td>\n      <td><span class=\"inverter-table__value inverter-table__value--efficiency {{efficiencyColor this.eficiencia_pct}}\">{{this.eficiencia_pct}}<span class=\"inverter-table__unit\">%</span></span></td>\n      <td><span class=\"inverter-table__value\">{{this.temp_c}}<span class=\"inverter-table__unit\">°C</span></span></td>\n      <td><span class=\"inverter-table__value\">{{this.freq_hz}}<span class=\"inverter-table__unit\">Hz</span></span></td>\n      <td><span class=\"inverter-table__value\">{{this.fp}}</span></td>\n      <td><span class=\"inverter-table__time\">{{this.ultima_leitura}}</span></td>\n    </tr>\n    {{/each}}\n  </tbody>\n</table>",
        "contentPartials": [],
        "defaultContent": "No inverters found for this power plant.",
        "editor": {
          "format": "auto",
          "language": "html"
        },
        "editors": [
          "helpers"
        ],
        "externalStyles": [],
        "helpers": "// Status class based on state_simplified\ncontext.handlebars.registerHelper('statusClass', function(state) {\n  return state === 2 ? 'inverter-table__status--generating' : 'inverter-table__status--critical';\n});\n\n// Status label\ncontext.handlebars.registerHelper('statusLabel', function(state) {\n  return state === 2 ? 'Generating' : 'Critical';\n});\n\n// Efficiency color\ncontext.handlebars.registerHelper('efficiencyColor', function(value) {\n  if (value >= 95) return 'inverter-table__value--good';\n  if (value >= 80) return 'inverter-table__value--warning';\n  return 'inverter-table__value--bad';\n});",
        "renderMode": "allRows",
