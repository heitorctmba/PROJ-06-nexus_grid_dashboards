        "helpers": "context.handlebars.registerHelper('countGenerating', function(data) {\n  return data.filter(d => d.state_simplified === 2).length;\n});\n\ncontext.handlebars.registerHelper('countCritical', function(data) {\n  return data.filter(d => d.state_simplified !== 2).length;\n});",
